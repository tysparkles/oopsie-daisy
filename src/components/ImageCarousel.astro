---
interface Props {
  items: {
    print: string;      // final artwork image
    process: string;     // behind the scenes / creative process
    package: string;     // physical package contents
    label?: string;      // e.g. "Cherry Blossom"
    month?: string;      // e.g. "June 2025"
    soldOut?: boolean;
  }[];
  archiveMode?: boolean; // slimmer cards for archive grid
}

const { items, archiveMode = false } = Astro.props;
---

<div class="carousel-wrapper w-full" data-carousel>
  <div class="carousel-track" data-carousel-track>
    {items.map((item, i) => (
      <div class="carousel-item" data-carousel-item>
        <div class="print-carousel" data-slides={JSON.stringify([item.print, item.process, item.package])}>

          <!-- Image stack -->
          <div class="slides-container" data-slides-container>
            {item.process && <img src={item.process} alt={`${item.label || 'Artwork'} — process`} class="slide-img" loading="lazy" />}
            {item.package && <img src={item.package} alt={`${item.label || 'Artwork'} — package`} class="slide-img" loading="lazy" />}
            <img src={item.print} alt={`${item.label || 'Artwork'} print`} class="slide-img active" loading="lazy" />
          </div>

          <!-- Dot nav -->
          <div class="dot-nav" data-dot-nav>
            <button class="dot active" data-dot="0" aria-label="Show print"></button>
            {item.process && <button class="dot" data-dot="1" aria-label="Show process"></button>}
            {item.package && <button class="dot" data-dot="2" aria-label="Show package"></button>}
          </div>

          <!-- Arrow nav -->
          <button class="arrow arrow-prev" data-prev aria-label="Previous image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>
          <button class="arrow arrow-next" data-next aria-label="Next image">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>

          <!-- Hover peek labels -->
          <div class="slide-labels" data-slide-labels>
            <span class="slide-label active">Print</span>
            {item.process && <span class="slide-label">Process</span>}
            {item.package && <span class="slide-label">Package</span>}
          </div>

          <!-- Sold out stamp -->
          {item.soldOut && (
            <div class="absolute top-3 right-3 stamp text-[9px] font-bold text-raspberry bg-white/90" style="border-color:#D44A65;transform:rotate(3deg);">
              SOLD OUT
            </div>
          )}

          <!-- Month tag -->
          {item.month && (
            <div class="absolute bottom-3 left-3 px-2.5 py-1 rounded-full text-[10px] font-heading font-bold uppercase tracking-wider text-white" style="background:rgba(61,43,43,0.7);backdrop-filter:blur(4px);">
              {item.month}
            </div>
          )}
        </div>

        {/* Card text below */}
        {!archiveMode && (
          <div class="mt-4">
            {item.label && (
              <h4 class="font-display text-xl text-contrast mb-1">{item.label}</h4>
            )}
            <p class="font-body text-sm text-contrast-muted leading-relaxed">
              <slot />
            </p>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('[data-carousel]').forEach((wrapper) => {
    const track = wrapper.querySelector('[data-carousel-track]') as HTMLElement;
    if (!track) return;

    // ── Horizontal scroll with mouse drag ──
    let isDragging = false;
    let startX = 0;
    let scrollLeft = 0;

    track.addEventListener('mousedown', (e: MouseEvent) => {
      isDragging = true;
      track.style.cursor = 'grabbing';
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
    });

    document.addEventListener('mouseup', () => {
      isDragging = false;
      track.style.cursor = 'grab';
    });

    track.addEventListener('mousemove', (e: MouseEvent) => {
      if (!isDragging) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      track.scrollLeft = scrollLeft - walk;
    });

    // ── Per-item carousel logic ──
    wrapper.querySelectorAll('[data-slides-container]').forEach((slides) => {
      const container = slides as HTMLElement;
      const imgs = container.querySelectorAll<HTMLImageElement>('.slide-img');
      const dots = container.parentElement?.querySelectorAll<HTMLButtonElement>('[data-dot]');
      const prevBtn = container.parentElement?.querySelector<HTMLButtonElement>('[data-prev]');
      const nextBtn = container.parentElement?.querySelector<HTMLButtonElement>('[data-next]');
      const labels = container.parentElement?.querySelectorAll<HTMLSpanElement>('.slide-label');
      let current = 0;

      function goTo(idx: number) {
        if (idx < 0) idx = imgs.length - 1;
        if (idx >= imgs.length) idx = 0;
        current = idx;
        imgs.forEach((img, i) => {
          img.classList.toggle('active', i === current);
          img.classList.toggle('prev', i === (current - 1 + imgs.length) % imgs.length);
        });
        dots?.forEach((d, i) => d.classList.toggle('active', i === current));
        labels?.forEach((l, i) => l.classList.toggle('active', i === current));
      }

      dots?.forEach((dot) => {
        dot.addEventListener('click', () => goTo(Number(dot.dataset.dot)));
      });

      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));

      // ── Touch / swipe support ──
      let touchStartX = 0;
      container.addEventListener('touchstart', (e: TouchEvent) => {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      container.addEventListener('touchend', (e: TouchEvent) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
          diff > 0 ? goTo(current + 1) : goTo(current - 1);
        }
      }, { passive: true });
    });
  });
</script>

<style>
  /* ── Carousel wrapper ── */
  .carousel-wrapper {
    overflow: hidden;
    position: relative;
  }
  .carousel-track {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    cursor: grab;
    padding-bottom: 8px;
    padding-left: 4px;
    padding-right: 4px;
  }
  .carousel-track::-webkit-scrollbar { display: none; }
  .carousel-item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    width: 260px;
  }

  /* ── Per-item slides ── */
  .print-carousel {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 4/5;
    background: #F7E4C4;
    box-shadow: 0 8px 32px rgba(212,74,101,0.15), 0 2px 8px rgba(61,43,43,0.08);
    border: 2px solid rgba(250,157,170,0.3);
    transition: box-shadow 0.4s ease, transform 0.4s cubic-bezier(0.34,1.56,0.64,1);
    user-select: none;
  }
  .print-carousel:hover {
    box-shadow: 0 16px 56px rgba(212,74,101,0.22), 0 4px 16px rgba(61,43,43,0.10);
    transform: translateY(-4px) rotate(0.3deg);
  }

  /* ── Slides ── */
  .slides-container {
    position: absolute;
    inset: 0;
  }
  .slide-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 16px;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.34,1.2,0.64,1);
  }
  .slide-img.active {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Dot nav ── */
  .dot-nav {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 10;
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: 1.5px solid rgba(255,255,255,0.8);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }
  .dot.active {
    background: #FA9DAA;
    border-color: #D44A65;
    transform: scale(1.3);
  }

  /* ── Arrow nav ── */
  .arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: rgba(255,255,255,0.92);
    border: 2px solid rgba(250,157,170,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    opacity: 0;
    transition: all 0.3s ease;
    color: #3D2B2B;
    box-shadow: 0 4px 16px rgba(61,43,43,0.15);
  }
  .print-carousel:hover .arrow { opacity: 1; }
  .arrow-prev { left: 10px; }
  .arrow-next { right: 10px; }
  .arrow:hover {
    background: #FA9DAA;
    border-color: #D44A65;
    color: white;
    transform: translateY(-50%) scale(1.1);
  }
  .arrow:active {
    transform: translateY(-50%) scale(0.95);
  }

  /* ── Slide labels ── */
  .slide-labels {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 10;
  }
  .slide-label {
    font-family: 'Nunito', sans-serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6);
    background: rgba(61,43,43,0.4);
    backdrop-filter: blur(4px);
    padding: 3px 8px;
    border-radius: 20px;
    opacity: 0;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }
  .slide-label.active { opacity: 1; }
</style>