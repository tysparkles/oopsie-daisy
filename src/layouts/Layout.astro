---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Oopsie Daisy — A monthly collectible print club. Hand painted originals, stickers & love letters delivered to your door across Canada.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <div class="grain-overlay"></div>
    <div class="atmospheric-haze"></div>
    <slot />

    <!-- ── Background Music ── -->
    <audio id="site-music" src="/media/music/this-side-of-heaven.m4a" loop preload="auto"></audio>

<script>
  (function() {
    // ── Scroll reveal ──
    var r = document.querySelectorAll('.scroll-reveal');
    if (r.length) {
      var o = new IntersectionObserver(function(e) {
        e.forEach(function(x) {
          if (x.isIntersecting) {
            x.target.classList.add('is-visible');
            o.unobserve(x.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
      r.forEach(function(el) { o.observe(el); });
    }

    // ── Petal fall parallax ──
    var petalEls = document.querySelectorAll('.animate-petal-fall');
    window.addEventListener('scroll', function() {
      var s = window.scrollY;
      petalEls.forEach(function(pet, i) {
        pet.style.transform = 'translateY(' + (s * (0.05 + i * 0.02)) + 'px)';
      });
    }, { passive: true });

    // ── Rotating archive gallery auto-scroll ──
    (function() {
      var wrap = document.getElementById('archive-gallery-wrap');
      var strip = document.getElementById('archive-gallery-strip');
      var lbtn = document.getElementById('gallery-left');
      var rbtn = document.getElementById('gallery-right');
      if (!wrap || !strip) return;
      var pos = 0, speed = 0.5, hovered = false, raf = null;
      function cw() { return (window.innerWidth < 640 ? 13 : 16) * 16 + 24; }
      if (lbtn) lbtn.onclick = function() { wrap.scrollLeft -= cw(); };
      if (rbtn) rbtn.onclick = function() { wrap.scrollLeft += cw(); };
      wrap.addEventListener('mouseenter', function() { hovered = true; cancelAnimationFrame(raf); }, { passive: true });
      wrap.addEventListener('mouseleave', function() { hovered = false; raf = requestAnimationFrame(tick); }, { passive: true });
      wrap.addEventListener('touchstart', function() { hovered = true; cancelAnimationFrame(raf); }, { passive: true });
      wrap.addEventListener('touchend', function() { hovered = false; raf = requestAnimationFrame(tick); }, { passive: true });
      wrap.addEventListener('scroll', function() {
        var max = strip.scrollWidth - wrap.clientWidth;
        if (wrap.scrollLeft >= max - 2) { wrap.scrollLeft = 1; pos = 1; }
        if (wrap.scrollLeft <= 0) { wrap.scrollLeft = max - wrap.clientWidth - 1; pos = wrap.scrollLeft; }
      }, { passive: true });
      function tick() { if (!hovered) { pos += speed; var max = strip.scrollWidth - wrap.clientWidth; if (pos >= max) pos = 1; wrap.scrollLeft = pos; } raf = requestAnimationFrame(tick); }
      raf = requestAnimationFrame(tick);
    })();

    // ── Autoplay music on first user interaction ──
    var music = document.getElementById('site-music') as HTMLAudioElement;
    var played = false;
    function startMusic() {
      if (played || !music) return;
      played = true;
      music.play().catch(function() {});
      document.removeEventListener('touchstart', startMusic);
      document.removeEventListener('click', startMusic);
    }
    document.addEventListener('touchstart', startMusic, { once: true, passive: true });
    document.addEventListener('click', startMusic, { once: true });
    // Attempt direct autoplay (browsers may block it)
    music.play().catch(function() {});
  })();
</script>

</body>
</html>