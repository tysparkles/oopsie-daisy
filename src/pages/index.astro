---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Oopsie Daisy — Monthly Print Club">

  <!-- ── STICKY NAV ── -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-fdf6ec/90 backdrop-blur-md border-b-2 border-lip-gloss/30">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 group">
        <!-- Mini daisy SVG logo -->
        <svg class="w-10 h-10" viewBox="0 0 50 50" fill="none">
          <circle cx="25" cy="25" r="7" fill="#FF9243"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(0 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(45 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(90 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(135 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(180 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(225 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(270 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#FA9DAA" transform="rotate(315 25 25)"/>
          <circle cx="25" cy="25" r="7" fill="#FF9243"/>
          <circle cx="23" cy="23" r="2" fill="#F7E4C4" opacity="0.6"/>
        </svg>
        <div>
          <span class="font-display text-xl text-text-dark leading-none">Oopsie Daisy</span>
          <span class="block font-heading text-[9px] font-bold tracking-[0.25em] text-raspberry uppercase -mt-1">Monthly Print Club</span>
        </div>
      </a>
      <div class="flex gap-6 items-center text-sm font-heading font-semibold">
        <a href="#this-month" class="hidden sm:block text-text-muted hover:text-raspberry transition-colors">This Month</a>
        <a href="#archive" class="hidden sm:block text-text-muted hover:text-raspberry transition-colors">Archive</a>
        <a href="#love-letters" class="hidden sm:block text-text-muted hover:text-raspberry transition-colors">Love Letters</a>
        <a href="#join" class="sticker-btn bg-raspberry text-white text-xs !py-2 !px-5 hover:bg-raspberry/90">Join the Club</a>
      </div>
    </div>
  </nav>

  <main>

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="min-h-screen relative overflow-hidden pt-28 pb-20 px-6">

      <!-- Background blobs -->
      <div class="absolute top-20 left-[-80px] w-96 h-96 bg-lip-gloss/20 rounded-full blur-[80px] animate-blob"></div>
      <div class="absolute bottom-20 right-[-60px] w-80 h-80 bg-sky-blue/30 rounded-full blur-[80px] animate-blob float-delay-2"></div>
      <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-soft-lavender/25 rounded-full blur-[60px] animate-blob float-delay-4"></div>

      <!-- Floating decorative elements -->
      <div class="absolute top-36 left-12 text-5xl animate-float-slow">✿</div>
      <div class="absolute top-52 right-16 text-4xl animate-float-med float-delay-1 rotate-12">✿</div>
      <div class="absolute bottom-48 left-20 text-3xl animate-float-fast float-delay-2">★</div>
      <div class="absolute top-40 left-1/4 text-2xl animate-wiggle">~</div>
      <div class="absolute bottom-36 right-1/4 text-3xl animate-drift">✧</div>
      <div class="absolute top-64 right-1/3 text-2xl animate-float-slow float-delay-3">❋</div>
      <div class="absolute bottom-24 left-1/3 text-4xl animate-float-med float-delay-4">✿</div>

      <!-- Decorative squiggle line -->
      <svg class="absolute left-0 top-1/2 w-32 h-20 opacity-30 animate-squiggle" viewBox="0 0 100 60" fill="none">
        <path d="M5 30 Q20 5 40 30 T80 30 T95 30" stroke="#D44A65" stroke-width="3" stroke-linecap="round" fill="none"/>
      </svg>

      <div class="relative z-10 max-w-3xl mx-auto text-center">

        <!-- Issue label -->
        <div class="inline-flex items-center gap-2 mb-8">
          <span class="w-8 h-[2px] bg-raspberry"></span>
          <span class="section-label">Issue No. 1 — June 2025</span>
          <span class="w-8 h-[2px] bg-raspberry"></span>
        </div>

        <!-- Big title -->
        <h1 class="font-display text-6xl md:text-8xl leading-[0.9] mb-4">
          <span class="text-raspberry">Oopsie</span>
          <br/>
          <span class="text-text-dark">Daisy</span>
        </h1>

        <!-- Subtitle with retro styling -->
        <p class="font-heading font-bold text-sm tracking-[0.35em] uppercase text-text-muted mb-10">
          — Monthly Print Club —
        </p>

        <!-- Tagline -->
        <p class="font-retro italic text-xl md:text-2xl text-text-dark/80 max-w-lg mx-auto mb-12 leading-relaxed">
          A little bundle of joy, delivered to your door. Art prints, hand-painted originals, stickers & love letters — made with matcha and soul.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
          <a href="#join" class="sticker-btn bg-raspberry text-white text-base">
            Join the Club ✦
          </a>
          <a href="#this-month" class="sticker-btn bg-transparent text-text-dark text-base border-text-dark/40 !border-2">
            See This Month
          </a>
        </div>

        <!-- Social proof sticker -->
        <div class="inline-flex items-center gap-3 bg-cake-batter border-2 border-text-dark/10 rounded-full px-5 py-3">
          <div class="flex -space-x-2">
            <div class="w-7 h-7 rounded-full bg-lip-gloss border-2 border-white text-xs flex items-center justify-center">T</div>
            <div class="w-7 h-7 rounded-full bg-soft-lavender border-2 border-white text-xs flex items-center justify-center">M</div>
            <div class="w-7 h-7 rounded-full bg-pale-mint border-2 border-white text-xs flex items-center justify-center">S</div>
            <div class="w-7 h-7 rounded-full bg-sky-blue border-2 border-white text-xs flex items-center justify-center">J</div>
          </div>
          <span class="text-sm font-heading font-semibold text-text-dark">
            1,200+ collectors across Canada
          </span>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
        <span class="text-[10px] font-heading font-bold tracking-[0.3em] uppercase text-text-muted/60">scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-text-muted/40 to-transparent"></div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         RAINBOW DIVIDER
    ══════════════════════════════════════════ -->
    <div class="rainbow-divider mx-6 rounded-full"></div>

    <!-- ══════════════════════════════════════════
         THIS MONTH'S ISSUE
    ══════════════════════════════════════════ -->
    <section id="this-month" class="py-24 px-6 relative">

      <!-- Background decorative -->
      <div class="absolute top-10 right-10 text-[120px] text-lip-gloss/10 font-display leading-none select-none pointer-events-none">✿</div>

      <div class="max-w-5xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <span class="section-label">This Month's Issue</span>
          <span class="flex-1 h-[2px] bg-lip-gloss/30 rounded"></span>
          <span class="stamp text-raspberry font-heading text-xs font-bold">JUNE 2025</span>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 items-center mt-6">

          <!-- Left: Text content -->
          <div>
            <h2 class="font-display text-5xl md:text-6xl text-text-dark mb-4 leading-[0.95]">
              Cherry<br/>
              <span class="text-raspberry">Blossom</span><br/>
              Season
            </h2>
            <p class="font-retro italic text-lg text-text-muted mb-8 leading-relaxed">
              "There's something about spring that makes everything feel a little more tender."
            </p>

            <div class="space-y-3 mb-8">
              <div class="flex items-center gap-3">
                <span class="text-raspberry font-heading font-bold">✦</span>
                <span class="font-body text-text-dark">5×7" archival art print — cherry blossom still life</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-tangerine font-heading font-bold">✦</span>
                <span class="font-body text-text-dark">Mini hand-painted koi fish on textured paper</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-vine-green font-heading font-bold">✦</span>
                <span class="font-body text-text-dark">Die-cut cherry blossom sticker sheet × 12</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-raspberry font-heading font-bold">✦</span>
                <span class="font-body text-text-dark">Handwritten love letter on wax seal paper</span>
              </div>
            </div>

            <a href="#join" class="sticker-btn bg-raspberry text-white">
              Get This Issue — Join the Club
            </a>
          </div>

          <!-- Right: Image / Print showcase -->
          <div class="relative">
            <!-- Scrapbook/paper layered effect -->
            <div class="relative">
              <!-- Back paper layer -->
              <div class="absolute -top-4 -left-4 w-full h-full bg-cake-batter rounded-2xl border-2 border-text-dark/10 rotate-[-2deg]"></div>
              <!-- Middle tape -->
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 z-10 w-20 h-6 bg-cake-batter/70 border border-text-dark/10 rotate-[2deg]"></div>
              <!-- Main image card -->
              <div class="relative bg-white rounded-2xl border-2 border-text-dark/10 p-4 shadow-float">
                <!-- Placeholder for print image -->
                <div class="aspect-[4/5] bg-gradient-to-br from-lip-gloss/30 via-sky-blue/20 to-soft-lavender/30 rounded-xl flex flex-col items-center justify-center relative overflow-hidden">
                  <!-- Decorative elements inside -->
                  <div class="absolute top-4 left-4 text-4xl opacity-40">✿</div>
                  <div class="absolute bottom-4 right-4 text-3xl opacity-40">✿</div>
                  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-center">
                    <div class="text-7xl mb-4">❀</div>
                    <span class="font-display text-text-muted text-lg">Cherry Blossom</span>
                    <span class="block font-heading text-xs tracking-widest uppercase text-text-muted/60 mt-1">June 2025 · Edition of 200</span>
                  </div>
                  <!-- Soft blur overlay for dreamy effect -->
                  <div class="absolute inset-0 backdrop-blur-[1px] pointer-events-none"></div>
                </div>
                <div class="mt-3 text-center">
                  <p class="font-heading font-bold text-sm text-text-dark">✿ 5×7" Archival Print + Hand Painted Original</p>
                  <p class="font-body text-xs text-text-muted mt-1">Limited to 200 numbered editions</p>
                </div>
              </div>
              <!-- Front sticker accent -->
              <div class="absolute -bottom-4 -right-4 z-20 bg-tangerine text-white rounded-full w-16 h-16 flex items-center justify-center text-center text-[10px] font-heading font-bold leading-tight p-1 shadow-sticker rotate-[8deg]">
                LIMITED<br/>RUN
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         WHAT'S INSIDE THE BOX
    ══════════════════════════════════════════ -->
    <section class="py-20 px-6 bg-cake-batter/40 relative">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2240%22%20height%3D%2240%22%20viewBox%3D%220%200%2040%2040%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22%23D44A65%22%20fill-opacity%3D%220.03%22%3E%3Ccircle%20cx%3D%2220%22%20cy%3D%2220%22%20r%3D%221%22%2F%3E%3C%2Fg%3E%3C%2Fsvg%3E')]"></div>
      <div class="max-w-5xl mx-auto relative z-10">

        <div class="text-center mb-14">
          <span class="section-label block mb-3">What's In The Box</span>
          <h2 class="font-display text-5xl text-text-dark">Every Month,<br/><span class="text-raspberry">A Little Universe</span></h2>
        </div>

        <div class="grid md:grid-cols-3 gap-6">

          <!-- Card 1 -->
          <div class="paper-card p-8 hover-lift">
            <div class="w-16 h-16 rounded-full bg-lip-gloss/20 flex items-center justify-center mb-5">
              <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none">
                <rect x="4" y="4" width="32" height="32" rx="4" fill="#FA9DAA" opacity="0.3"/>
                <rect x="8" y="8" width="24" height="24" rx="3" stroke="#D44A65" stroke-width="2" fill="none"/>
                <line x1="12" y1="18" x2="28" y2="18" stroke="#D44A65" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="12" y1="22" x2="22" y2="22" stroke="#D44A65" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl text-text-dark mb-3">The Art Print</h3>
            <p class="font-body text-text-muted leading-relaxed text-sm">A 5×7" archival-quality print on thick textured paper. Each issue features a brand new original illustration — exclusive, numbered, never reprinted.</p>
          </div>

          <!-- Card 2 -->
          <div class="paper-card p-8 hover-lift">
            <div class="w-16 h-16 rounded-full bg-tangerine/20 flex items-center justify-center mb-5">
              <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none">
                <path d="M20 6 C20 6 8 14 8 24 C8 30 13 35 20 35 C27 35 32 30 32 24 C32 14 20 6 20 6Z" fill="#FF9243" opacity="0.3"/>
                <path d="M20 8 C20 8 10 15 10 24 C10 29 14 33 20 33" stroke="#D44A65" stroke-width="2" fill="none" stroke-linecap="round"/>
                <circle cx="17" cy="22" r="2" fill="#D44A65"/>
                <circle cx="23" cy="24" r="1.5" fill="#D44A65"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl text-text-dark mb-3">Hand Painted Original</h3>
            <p class="font-body text-text-muted leading-relaxed text-sm">A real, tiny, one-of-a-kind painting made by my actual hands. No prints, no copies — just a small, unique artwork created with love and messy brushes.</p>
          </div>

          <!-- Card 3 -->
          <div class="paper-card p-8 hover-lift">
            <div class="w-16 h-16 rounded-full bg-soft-lavender/30 flex items-center justify-center mb-5">
              <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none">
                <path d="M8 10 L28 10 L32 18 L28 34 L12 34 L8 18 Z" fill="#D5C6E8" opacity="0.4"/>
                <path d="M10 12 L26 12 L29 18 L26 32 L14 32 L10 18 Z" stroke="#D44A65" stroke-width="1.5" fill="none"/>
                <line x1="16" y1="20" x2="24" y2="20" stroke="#D44A65" stroke-width="1" stroke-linecap="round"/>
                <line x1="16" y1="24" x2="22" y2="24" stroke="#D44A65" stroke-width="1" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl text-text-dark mb-3">Stickers & Letter</h3>
            <p class="font-body text-text-muted leading-relaxed text-sm">A sheet of die-cut stickers from this month's artwork, plus a handwritten letter on real paper sharing the story, inspiration, and a little bit of my heart.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         ARCHIVE / PAST DROPS
    ══════════════════════════════════════════ -->
    <section id="archive" class="py-24 px-6 relative overflow-hidden">

      <!-- Decorative bg -->
      <div class="absolute top-0 right-0 text-[200px] text-lip-gloss/[0.04] font-display leading-none select-none pointer-events-none">❀</div>

      <div class="max-w-5xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <span class="section-label">Club Archive</span>
          <span class="flex-1 h-[2px] bg-lip-gloss/30 rounded"></span>
          <span class="font-heading text-xs text-text-muted">Past Print Drops</span>
        </div>

        <h2 class="font-display text-5xl text-text-dark mb-14 mt-4">
          The Collection
        </h2>

        <div class="grid md:grid-cols-3 gap-8">

          <!-- Archive item 1 -->
          <div class="group">
            <div class="aspect-[3/4] bg-gradient-to-br from-peach-cream to-lip-gloss/30 rounded-2xl border-2 border-text-dark/10 overflow-hidden relative mb-4 hover-lift">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <div class="text-5xl mb-2">❀</div>
                  <span class="font-heading text-xs tracking-widest uppercase text-text-muted">May 2025</span>
                </div>
              </div>
              <!-- Sold out stamp -->
              <div class="absolute top-3 right-3 stamp text-[9px] font-bold text-text-muted bg-white/80">SOLD OUT</div>
            </div>
            <h4 class="font-display text-xl text-text-dark">Matcha & Mornings</h4>
            <p class="font-body text-xs text-text-muted mt-1">Warm pastry still life · Coffee cup study · Strawberry stickers</p>
          </div>

          <!-- Archive item 2 -->
          <div class="group">
            <div class="aspect-[3/4] bg-gradient-to-br from-sky-blue/20 to-soft-lavender/30 rounded-2xl border-2 border-text-dark/10 overflow-hidden relative mb-4 hover-lift">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <div class="text-5xl mb-2">☀</div>
                  <span class="font-heading text-xs tracking-widest uppercase text-text-muted">April 2025</span>
                </div>
              </div>
              <div class="absolute top-3 right-3 stamp text-[9px] font-bold text-text-muted bg-white/80">SOLD OUT</div>
            </div>
            <h4 class="font-display text-xl text-text-dark">Sunflower Season</h4>
            <p class="font-body text-xs text-text-muted mt-1">Sunflower field print · Bee study · Honey jar stickers</p>
          </div>

          <!-- Archive item 3 -->
          <div class="group">
            <div class="aspect-[3/4] bg-gradient-to-br from-pale-mint/30 to-vine-green/20 rounded-2xl border-2 border-text-dark/10 overflow-hidden relative mb-4 hover-lift">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="text-center">
                  <div class="text-5xl mb-2">✿</div>
                  <span class="font-heading text-xs tracking-widest uppercase text-text-muted">March 2025</span>
                </div>
              </div>
              <div class="absolute top-3 right-3 stamp text-[9px] font-bold text-text-muted bg-white/80">SOLD OUT</div>
            </div>
            <h4 class="font-display text-xl text-text-dark">First Bloom</h4>
            <p class="font-body text-xs text-text-muted mt-1">Wildflower collage · Pressed flower card · Leaf stickers</p>
          </div>

        </div>

        <div class="text-center mt-10">
          <p class="font-retro italic text-text-muted text-lg">More issues added every month — join to collect them all.</p>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════
         LOVE LETTERS / TESTIMONIALS
    ══════════════════════════════════════════ -->
    <section id="love-letters" class="py-24 px-6 bg-raspberry/5 relative">
      <div class="max-w-4xl mx-auto">

        <div class="text-center mb-14">
          <span class="section-label block mb-3">Love Letters</span>
          <h2 class="font-display text-5xl text-text-dark">
            What Collectors <span class="text-raspberry">Say</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-6">

          <!-- Testimonial 1 -->
          <div class="paper-card p-7 relative washi-left">
            <p class="font-retro italic text-text-dark leading-relaxed mb-5">
              "Opening my Oopsie Daisy box is genuinely the highlight of my month. The handwriting on the letter alone made me cry. It feels like receiving a gift from a friend who really gets me."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-lip-gloss flex items-center justify-center text-white font-heading font-bold text-sm">M</div>
              <div>
                <p class="font-heading font-bold text-sm text-text-dark">Mia R.</p>
                <p class="font-body text-xs text-text-muted">Vancouver, BC · 4 issues</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 2 -->
          <div class="paper-card p-7 relative washi-left" style="--tw-border-opacity: 0.08;">
            <div style="position:absolute;top:-10px;left:-5px;width:80px;height:22px;background:repeating-linear-gradient(-45deg,rgba(168,187,62,0.5),rgba(168,187,62,0.5) 4px,rgba(168,187,62,0.2) 4px,rgba(168,187,62,0.2) 8px);border-radius:2px;transform:rotate(8deg);"></div>
            <p class="font-retro italic text-text-dark leading-relaxed mb-5">
              "I have a gallery wall just for my Oopsie Daisy prints now. My apartment feels like a museum of things I actually love. The hand-painted pieces are insane, how is it so good?"
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-soft-lavender flex items-center justify-center text-white font-heading font-bold text-sm">J</div>
              <div>
                <p class="font-heading font-bold text-sm text-text-dark">Jess T.</p>
                <p class="font-body text-xs text-text-muted">Toronto, ON · 8 issues</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 3 -->
          <div class="paper-card p-7 relative">
            <div style="position:absolute;top:-10px;right:20px;width:80px;height:22px;background:repeating-linear-gradient(45deg,rgba(245,157,170,0.5),rgba(245,157,170,0.5) 4px,rgba(245,157,170,0.2) 4px,rgba(245,157,170,0.2) 8px);border-radius:2px;transform:rotate(-5deg);"></div>
            <p class="font-retro italic text-text-dark leading-relaxed mb-5">
              "The matcha one was so specific and personal to my life that I genuinely don't know how you understood me that well. This is internet magic. I love it here."
            </p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-pale-mint flex items-center justify-center text-white font-heading font-bold text-sm">S</div>
              <div>
                <p class="font-heading font-bold text-sm text-text-dark">Sam K.</p>
                <p class="font-body text-xs text-text-muted">Montreal, QC · 6 issues</p>
              </div>
            </div>
          </div>

          <!-- Testimonial 4 -->
          <div class="paper-card p-7 relative">
            <div style="position:absolute;top:-10px;right:20px;width:80px;height:22px;background:repeating-linear-gradient(45deg,rgba(255,146,67,0.4),rgba(255,146,67,0.4) 4px,rgba(255,146,67,0.15) 4px,rgba(255,146,67,0.15) 8px);border-radius:2px;transform:rotate(-5deg);"></div>
            <p class="font-retro italic text-text-dark leading-relaxed mb-5">
              "Gave a 3-month subscription to my sister as a birthday gift and now she's obsessed too. We've started collecting together. It's kind of the sweetest thing."
            </p>
            <div class="flex items-center gap-3">
