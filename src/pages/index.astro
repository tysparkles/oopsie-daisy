// Music state
const musicEnabled = true;
---

<Layout title="Oopsie Daisy — Monthly Print Club">

  <!-- ── STICKY NAV ── -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-warm-cream/15" style="background:linear-gradient(180deg,rgba(74,67,54,0.62),rgba(74,67,54,0.28) 70%,rgba(74,67,54,0));backdrop-filter:blur(10px);">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 group logo-daisy-wrap">
        <!-- Mini daisy SVG logo -->
        <svg class="w-10 h-10 logo-daisy" viewBox="0 0 50 50" fill="none">
          <circle cx="25" cy="25" r="7" fill="#A55230"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(0 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(45 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(90 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(135 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(180 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(225 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(270 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(315 25 25)"/>
          <circle cx="25" cy="25" r="7" fill="#A55230"/>
          <circle cx="23" cy="23" r="2" fill="#D4BB9D" opacity="0.6"/>
        </svg>
        <div>
          <span class="font-display text-xl text-warm-cream leading-none" style="text-shadow:0 2px 14px rgba(74,67,54,0.42);">Oopsie Daisy</span>
          <span class="block font-heading text-[9px] font-bold tracking-[0.25em] text-warm-cream/85 uppercase -mt-1" style="text-shadow:0 2px 12px rgba(74,67,54,0.35);">Monthly Print Club</span>
        </div>
      </a>
      <div class="flex gap-6 items-center text-sm font-heading font-semibold">
        <a href="#this-month" class="hidden sm:block text-warm-cream/85 hover:text-warm-cream transition-colors hw-underline">This Month</a>
        <a href="#archive" class="hidden sm:block text-warm-cream/85 hover:text-warm-cream transition-colors hw-underline">Archive</a>
        <a href="#love-letters" class="hidden sm:block text-warm-cream/85 hover:text-warm-cream transition-colors hw-underline">Love Letters</a>
        <a href="#join" class="sticker-btn sticker-btn-orange text-xs !py-2 !px-5">Join the Club</a>
      </div>
    </div>
  </nav>

  <main>

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="min-h-screen relative overflow-hidden pt-28 pb-20 px-6" style="background: linear-gradient(160deg, #D4BB9D 0%, #E7C7AF 44%, #D45C74 82%, #A55230 100%);">

      <!-- ── HERO VIDEO / IMAGE BACKGROUND ── -->
      <!-- TO USE: Replace the src below with your video URL or local path like /media/hero-video.mp4 -->
      <!-- Leave src empty to show the abstract animated background instead -->
      <div class="hero-video-container">
        <video class="hero-video" src="/media/photos/opening.mp4" muted playsinline aria-hidden="true"></video>
        <video class="hero-video" src="/media/photos/drawing.mp4" muted playsinline aria-hidden="true"></video>
        <video class="hero-video" src="/media/photos/opening lying.mp4" muted playsinline aria-hidden="true"></video>
        <video class="hero-video" src="/media/photos/daisies.mp4" muted playsinline aria-hidden="true"></video>
        <video class="hero-video" src="/media/photos/opening run.mp4" muted playsinline aria-hidden="true"></video>
      </div>
      <!-- Fallback: large static image (shown if no video src) -->
      <!-- <img class="hero-media-bg" src="/media/hero-image.jpg" alt="" aria-hidden="true" /> -->
      <!-- Gradient overlay for text readability -->
      <div class="hero-media-overlay"></div>
      <!-- Film grain overlay -->
      <div class="hero-film-grain"></div>
      <!-- Dreamy bloom haze -->
      <div class="hero-bloom"></div>



      <div class="absolute top-32 right-24 text-3xl animate-flower-sway float-delay-2"><svg width="28" height="28" viewBox="0 0 50 50" fill="none" class="inline-block animate-flower-sway"><circle cx="25" cy="25" r="6" fill="#A55230"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(0 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(60 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(120 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(180 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(240 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(300 25 25)"/><circle cx="25" cy="25" r="6" fill="#A55230"/><circle cx="23.5" cy="23.5" r="2" fill="#D4BB9D" opacity="0.5"/></svg></div>
      <div class="absolute bottom-40 left-16 text-2xl animate-flower-sway float-delay-3"><svg width="18" height="18" viewBox="0 0 50 50" fill="none" class="inline-block animate-flower-sway" style="animation-duration:8s;"><circle cx="25" cy="25" r="6" fill="#D45C74" opacity="0.7"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(0 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(45 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(90 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(135 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(180 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(225 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(270 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(315 25 25)"/><circle cx="25" cy="25" r="6" fill="#D45C74" opacity="0.7"/></svg></div>
      <div class="absolute top-48 left-1/3 text-xl animate-sparkle">✦</div>
      <div class="absolute bottom-52 right-1/4 text-lg animate-sparkle sparkle-delay-1">✦</div>
      <div class="absolute top-72 right-1/2 text-2xl animate-flower-sway float-delay-4"><svg width="18" height="18" viewBox="0 0 50 50" fill="none" class="inline-block animate-flower-sway" style="animation-duration:8s;"><circle cx="25" cy="25" r="6" fill="#D45C74" opacity="0.7"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(0 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(45 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(90 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(135 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(180 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(225 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(270 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(315 25 25)"/><circle cx="25" cy="25" r="6" fill="#D45C74" opacity="0.7"/></svg></div>

      <!-- Background blobs (shown when no hero media) -->
      <div class="absolute top-20 left-[-80px] w-96 h-96 bg-coral-pink/20 rounded-full blur-[80px] animate-blob"></div>
      <div class="absolute bottom-20 right-[-60px] w-80 h-80 bg-warm-cream/25 rounded-full blur-[80px] animate-blob float-delay-2"></div>
      <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-burnt-cinnamon/10 rounded-full blur-[60px] animate-blob float-delay-4"></div>

      <!-- Floating decorative elements -->
      <div class="absolute top-36 left-12 text-5xl animate-float-slow">✿</div>
      <div class="absolute top-52 right-16 text-4xl animate-float-med float-delay-1 rotate-12">✿</div>
      <div class="absolute bottom-48 left-20 text-3xl animate-float-fast float-delay-2">★</div>
      <div class="absolute top-40 left-1/4 text-2xl animate-wiggle">~</div>
      <div class="absolute bottom-36 right-1/4 text-3xl animate-drift">✧</div>
      <div class="absolute top-64 right-1/3 text-2xl animate-float-slow float-delay-3">❋</div>
      <div class="absolute bottom-24 left-1/3 text-4xl animate-float-med float-delay-4">✿</div>


      <!-- Decorative daisies around pricing -->
      <div class="absolute top-10 left-8 text-4xl animate-flower-sway opacity-70"><svg width="28" height="28" viewBox="0 0 50 50" fill="none" class="inline-block animate-flower-sway"><circle cx="25" cy="25" r="6" fill="#A55230"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(0 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(60 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(120 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(180 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(240 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(300 25 25)"/><circle cx="25" cy="25" r="6" fill="#A55230"/><circle cx="23.5" cy="23.5" r="2" fill="#D4BB9D" opacity="0.5"/></svg></div>
      <div class="absolute bottom-12 right-10 text-3xl animate-flower-sway float-delay-2 opacity-70"><svg width="28" height="28" viewBox="0 0 50 50" fill="none" class="inline-block animate-flower-sway"><circle cx="25" cy="25" r="6" fill="#A55230"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(0 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(60 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(120 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(180 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(240 25 25)"/><ellipse cx="25" cy="10" rx="5" ry="8" fill="#DE7B5B" transform="rotate(300 25 25)"/><circle cx="25" cy="25" r="6" fill="#A55230"/><circle cx="23.5" cy="23.5" r="2" fill="#D4BB9D" opacity="0.5"/></svg></div>
      <div class="absolute top-1/2 left-4 text-2xl animate-sparkle opacity-60">✦</div>
      <div class="absolute top-1/3 right-8 text-xl animate-sparkle sparkle-delay-1 opacity-60">✦</div>
      <div class="absolute bottom-1/3 right-16 text-2xl animate-flower-sway float-delay-3 opacity-50"><svg width="18" height="18" viewBox="0 0 50 50" fill="none" class="inline-block animate-flower-sway" style="animation-duration:8s;"><circle cx="25" cy="25" r="6" fill="#D45C74" opacity="0.7"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(0 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(45 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(90 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(135 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(180 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(225 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(270 25 25)"/><ellipse cx="25" cy="10" rx="4" ry="7" fill="#DE7B5B" opacity="0.7" transform="rotate(315 25 25)"/><circle cx="25" cy="25" r="6" fill="#D45C74" opacity="0.7"/></svg></div>

      <!-- Decorative squiggle line -->
      <svg class="absolute left-0 top-1/2 w-32 h-20 opacity-30 animate-squiggle" viewBox="0 0 100 60" fill="none">
        <path d="M5 30 Q20 5 40 30 T80 30 T95 30" stroke="#D45C74" stroke-width="3" stroke-linecap="round" fill="none"/>
      </svg>

      <div class="relative z-10 max-w-3xl mx-auto text-center">

        <!-- Issue label -->
        <div class="inline-flex items-center gap-2 mb-8">
          <span class="w-8 h-[2px] bg-white/50"></span>
          <span class="section-label text-white/85">Issue No. 1 — June 2025</span>
          <span class="w-8 h-[2px] bg-white/50"></span>
        </div>

        <!-- Big title -->
        <h1 class="font-display text-6xl md:text-8xl leading-[0.9] mb-4">
          <span class="text-white">Oopsie</span>
          <br/>
          <span class="text-white/90">Daisy</span>
        </h1>

        <!-- Subtitle with retro styling -->
        <p class="font-heading font-bold text-sm tracking-[0.35em] uppercase text-white/85 mb-10">
          — Monthly Print Club —
        </p>

        <!-- Tagline -->
        <p class="font-marykate text-xl md:text-2xl text-white/85 max-w-lg mx-auto mb-12">
          A little bundle of joy, delivered to your door. Art prints, hand-painted originals, stickers & love letters — made with matcha and soul.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
          <a href="#join" class="sticker-btn bg-warm-cream text-contrast text-base font-heading font-bold">
            Join the Club ✦
          </a>
          <a href="#this-month" class="sticker-btn bg-white/20 !text-white text-base border-white/40 !border border-white/30 backdrop-blur-sm">
            See This Month
          </a>
        </div>

        <!-- Social proof sticker -->
        <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-5 py-3">
          <div class="flex -space-x-2">
            <div class="w-7 h-7 rounded-full bg-coral-pink border-2 border-white/60 text-xs flex items-center justify-center">T</div>
            <div class="w-7 h-7 rounded-full bg-warm-cream border-2 border-white/60 text-xs flex items-center justify-center">M</div>
            <div class="w-7 h-7 rounded-full bg-olive-green border-2 border-white/60 text-xs flex items-center justify-center">S</div>
            <div class="w-7 h-7 rounded-full bg-warm-cream border-2 border-white/60 text-xs flex items-center justify-center">J</div>
          </div>
          <span class="text-sm font-heading font-semibold text-white/85">
            1,200+ collectors across Canada
          </span>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
        <span class="text-[10px] font-heading font-bold tracking-[0.3em] uppercase text-white/50">scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-text-muted/40 to-transparent"></div>
      </div>
    </section>
    <section id="this-month" class="py-28 px-6 relative" style="background: linear-gradient(160deg, #D4BB9D 0%, #E7C7AF 58%, #DE7B5B 100%);">
      <!-- Background decorative -->
      <div class="absolute top-10 right-10 text-[120px] text-coral-pink/10 font-display leading-none select-none pointer-events-none">✿</div>
      <div class="absolute bottom-20 left-0 w-64 h-64 bg-dusty-pink/10 rounded-full blur-[60px] animate-blob"></div>

