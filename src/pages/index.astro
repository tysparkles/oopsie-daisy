---
import Layout from '../layouts/Layout.astro';
import ImageCarousel from '../components/ImageCarousel.astro';
---

<Layout title="Oopsie Daisy — Monthly Print Club">

  <!-- ── STICKY NAV ── -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-warm-cream/15" style="background:linear-gradient(180deg,rgba(74,67,54,0.62),rgba(74,67,54,0.28) 70%,rgba(74,67,54,0));backdrop-filter:blur(10px);">
    <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 group logo-daisy-wrap">
        <!-- Mini daisy SVG logo -->
        <svg class="w-10 h-10 logo-daisy" viewBox="0 0 50 50" fill="none">
          <circle cx="25" cy="25" r="7" fill="#A55230"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(0 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(45 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(90 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(135 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(180 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(225 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(270 25 25)"/>
          <ellipse cx="25" cy="11" rx="6" ry="9" fill="#DE7B5B" transform="rotate(315 25 25)"/>
          <circle cx="25" cy="25" r="7" fill="#A55230"/>
          <circle cx="23" cy="23" r="2" fill="#D4BB9D" opacity="0.6"/>
        </svg>
        <div>
          <span class="font-display text-xl text-warm-cream leading-none" style="text-shadow:0 2px 14px rgba(74,67,54,0.42);">Oopsie Daisy</span>
          <span class="block font-heading text-[9px] font-bold tracking-[0.25em] text-warm-cream/85 uppercase -mt-1" style="text-shadow:0 2px 12px rgba(74,67,54,0.35);">Monthly Print Club</span>
        </div>
      </a>
      <div class="flex gap-6 items-center text-sm font-heading font-semibold">
        <a href="#this-month" class="hidden sm:block text-warm-cream/85 hover:text-warm-cream transition-colors hw-underline">This Month</a>
        <a href="#archive" class="hidden sm:block text-warm-cream/85 hover:text-warm-cream transition-colors hw-underline">Archive</a>
        <a href="#love-letters" class="hidden sm:block text-warm-cream/85 hover:text-warm-cream transition-colors hw-underline">Love Letters</a>
        <a href="#join" class="sticker-btn bg-warm-cream text-espresso text-xs !py-2 !px-5">Join the Club</a>
      </div>
    </div>
  </nav>

  <main>

    <!-- ══════════════════════════════════════════
         HERO
    ══════════════════════════════════════════ -->
    <section class="min-h-screen relative overflow-hidden pt-28 pb-20 px-6" style="background: linear-gradient(160deg, #D4BB9D 0%, #E7C7AF 44%, #D45C74 82%, #A55230 100%);">

      <!-- ── HERO VIDEO / IMAGE BACKGROUND ── -->
      <!-- TO USE: Replace the src below with your video URL or local path like /media/hero-video.mp4 -->
      <!-- Leave src empty to show the abstract animated background instead -->
      <video
        class="hero-media-bg"
        src="/media/photos/opening.mp4"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      ></video>
      <!-- Fallback: large static image (shown if no video src) -->
      <!-- <img class="hero-media-bg" src="/media/hero-image.jpg" alt="" aria-hidden="true" /> -->
      <!-- Gradient overlay for text readability -->
      <div class="hero-media-overlay"></div>
      <!-- Film grain overlay -->
      <div class="hero-film-grain"></div>
      <!-- Dreamy bloom haze -->
      <div class="hero-bloom"></div>


      <!-- Background blobs (shown when no hero media) -->
      <div class="absolute top-20 left-[-80px] w-96 h-96 bg-coral-pink/20 rounded-full blur-[80px] animate-blob"></div>
      <div class="absolute bottom-20 right-[-60px] w-80 h-80 bg-warm-cream/25 rounded-full blur-[80px] animate-blob float-delay-2"></div>
      <div class="absolute top-1/3 right-1/4 w-64 h-64 bg-burnt-cinnamon/10 rounded-full blur-[60px] animate-blob float-delay-4"></div>

      <!-- Floating decorative elements -->
      <div class="absolute top-36 left-12 text-5xl animate-float-slow">✿</div>
      <div class="absolute top-52 right-16 text-4xl animate-float-med float-delay-1 rotate-12">✿</div>
      <div class="absolute bottom-48 left-20 text-3xl animate-float-fast float-delay-2">★</div>
      <div class="absolute top-40 left-1/4 text-2xl animate-wiggle">~</div>
      <div class="absolute bottom-36 right-1/4 text-3xl animate-drift">✧</div>
      <div class="absolute top-64 right-1/3 text-2xl animate-float-slow float-delay-3">❋</div>
      <div class="absolute bottom-24 left-1/3 text-4xl animate-float-med float-delay-4">✿</div>

      <!-- Decorative squiggle line -->
      <svg class="absolute left-0 top-1/2 w-32 h-20 opacity-30 animate-squiggle" viewBox="0 0 100 60" fill="none">
        <path d="M5 30 Q20 5 40 30 T80 30 T95 30" stroke="#D45C74" stroke-width="3" stroke-linecap="round" fill="none"/>
      </svg>

      <div class="relative z-10 max-w-3xl mx-auto text-center">

        <!-- Issue label -->
        <div class="inline-flex items-center gap-2 mb-8">
          <span class="w-8 h-[2px] bg-white/50"></span>
          <span class="section-label text-white/85">Issue No. 1 — June 2025</span>
          <span class="w-8 h-[2px] bg-white/50"></span>
        </div>

        <!-- Big title -->
        <h1 class="font-display text-6xl md:text-8xl leading-[0.9] mb-4">
          <span class="text-white">Oopsie</span>
          <br/>
          <span class="text-white/90">Daisy</span>
        </h1>

        <!-- Subtitle with retro styling -->
        <p class="font-heading font-bold text-sm tracking-[0.35em] uppercase text-white/85 mb-10">
          — Monthly Print Club —
        </p>

        <!-- Tagline -->
        <p class="font-marykate font-marykate-animated italic text-xl md:text-2xl text-white/85 max-w-lg mx-auto mb-12">
          A little bundle of joy, delivered to your door. Art prints, hand-painted originals, stickers & love letters — made with matcha and soul.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
          <a href="#join" class="sticker-btn bg-white text-dusty-pink text-base font-heading font-bold">
            Join the Club ✦
          </a>
          <a href="#this-month" class="sticker-btn bg-white/20 !text-white text-base border-white/40 !border border-white/30 backdrop-blur-sm">
            See This Month
          </a>
        </div>

        <!-- Social proof sticker -->
        <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-5 py-3">
          <div class="flex -space-x-2">
            <div class="w-7 h-7 rounded-full bg-coral-pink border-2 border-white/60 text-xs flex items-center justify-center">T</div>
            <div class="w-7 h-7 rounded-full bg-warm-cream border-2 border-white/60 text-xs flex items-center justify-center">M</div>
            <div class="w-7 h-7 rounded-full bg-olive-green border-2 border-white/60 text-xs flex items-center justify-center">S</div>
            <div class="w-7 h-7 rounded-full bg-warm-cream border-2 border-white/60 text-xs flex items-center justify-center">J</div>
          </div>
          <span class="text-sm font-heading font-semibold text-white/85">
            1,200+ collectors across Canada
          </span>
        </div>
      </div>

      <!-- Scroll hint -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2">
        <span class="text-[10px] font-heading font-bold tracking-[0.3em] uppercase text-white/50">scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-text-muted/40 to-transparent"></div>
      </div>
    </section>
    <section id="this-month" class="py-28 px-6 relative" style="background: linear-gradient(160deg, #D4BB9D 0%, #E7C7AF 58%, #DE7B5B 100%);">
      <!-- Background decorative -->
      <div class="absolute top-10 right-10 text-[120px] text-coral-pink/10 font-display leading-none select-none pointer-events-none">✿</div>
      <div class="absolute bottom-20 left-0 w-64 h-64 bg-dusty-pink/10 rounded-full blur-[60px] animate-blob"></div>

      <div class="max-w-6xl mx-auto">

        <div class="flex items-center gap-4 mb-8">
          <span class="section-label">This Month's Issue</span>
          <span class="flex-1 h-[2px] bg-coral-pink/30 rounded"></span>
          <span class="stamp text-dusty-pink font-heading text-xs font-bold">JUNE 2025</span>
        </div>

        <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-center">
          <!-- Left: Text content -->
          <div class="lg:col-span-5">
            <h2 class="font-display text-5xl md:text-6xl text-contrast mb-4 leading-[0.95]">
              Cherry<br/>
              <span class="text-dusty-pink">Blossom</span><br/>
              Season
            </h2>
            <p class="font-marykate italic text-lg md:text-xl text-contrast-muted mb-8">
              "There's something about spring that makes everything feel a little more tender."
            </p>

            <div class="space-y-3 mb-8">
              <div class="flex items-center gap-3">
                <span class="text-dusty-pink font-heading font-bold">✦</span>
                <span class="font-body text-contrast">5×7" archival art print — cherry blossom still life</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-burnt-cinnamon font-heading font-bold">✦</span>
                <span class="font-body text-contrast">Mini hand-painted koi fish on textured paper</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-olive-green font-heading font-bold">✦</span>
                <span class="font-body text-contrast">Die-cut cherry blossom sticker sheet × 12</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-dusty-pink font-heading font-bold">✦</span>
                <span class="font-body text-contrast">Handwritten love letter on wax seal paper</span>
              </div>
            </div>

            <a href="#join" class="sticker-btn bg-dusty-pink text-white">
              Get This Issue — Join the Club
            </a>

            <!-- Swipe hint -->
            <p class="mt-4 text-xs font-heading text-contrast-muted/60 flex items-center gap-1">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              Swipe to see print, process & package
            </p>
          </div>

          <!-- Right: Image Carousel (3/5 width) -->
          <!-- To use your own images: replace the src values below with paths like /media/prints/your-image.jpg -->
          <div class="lg:col-span-7">
            <ImageCarousel items={[{
              print: '/media/prints/cherry blossom.png',
              process: 'https://images.unsplash.com/photo-1513519245088-0e12902e5a38?w=800&q=80',
              package: 'https://images.unsplash.com/photo-1607082349566-187342175e2f?w=800&q=80',
              label: 'Cherry Blossom Season',
              month: 'June 2025',
              soldOut: false,
            }, {
              print: '/media/photos/print club.png',
              process: 'https://images.unsplash.com/photo-1513519245088-0e12902e5a38?w=800&q=80',
              package: 'https://images.unsplash.com/photo-1607082349566-187342175e2f?w=800&q=80',
              label: 'Print Club Box',
              month: 'June 2025',
              soldOut: false,
            }]} />
            <p class="mt-4 text-center font-heading text-sm text-contrast-muted">
              Swipe or tap arrows to explore — print, process & package
            </p>
          </div>
        </div>
      </div>
    </section>
    <section class="py-24 px-6 relative overflow-hidden" style="background: linear-gradient(160deg, #E7C7AF 0%, #D4BB9D 58%, #DE7B5B 100%);">
      <!-- Pastel blob decorations -->
      <div class="absolute top-10 right-20 w-72 h-72 blob-pink rounded-full blur-[80px] animate-blob"></div>
      <div class="absolute bottom-10 left-10 w-60 h-60 blob-peach rounded-full blur-[70px] animate-blob float-delay-2"></div>
      <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2240%22%20height%3D%2240%22%20viewBox%3D%220%200%2040%2040%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22%234A4336%22%20fill-opacity%3D%220.035%22%3E%3Ccircle%20cx%3D%2220%22%20cy%3D%2220%22%20r%3D%221%22%2F%3E%3C%2Fg%3E%3C%2Fsvg%3E')]"></div>
      <div class="max-w-5xl mx-auto relative z-10">

        <div class="text-center mb-14">
          <span class="section-label block mb-3">What's In The Box</span>
          <h2 class="font-display text-5xl text-text-dark">Every Month,<br/><span class="text-dusty-pink">A Little Universe</span></h2>
        </div>

        <div class="grid md:grid-cols-3 gap-8">

          <!-- Card 1 — Art Print -->
          <div class="paper-card p-8 hover-lift">
            <div class="w-16 h-16 rounded-full bg-coral-pink/20 flex items-center justify-center mb-5">
              <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none">
                <rect x="6" y="8" width="28" height="24" rx="3" stroke="#D45C74" stroke-width="2" fill="none"/>
                <path d="M6 28 L14 20 L20 26 L26 19 L34 28" stroke="#D45C74" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="13" cy="14" r="3" stroke="#DE7B5B" stroke-width="1.5" fill="none"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl text-contrast mb-3">Art Print</h3>
            <p class="font-body text-contrast-muted leading-relaxed text-sm">Exclusive monthly collectible artwork designed around the current theme and emotional mood of the month.</p>
          </div>

          <!-- Card 2 — Handwritten Letter -->
          <div class="paper-card p-8 hover-lift">
            <div class="w-16 h-16 rounded-full bg-burnt-cinnamon/20 flex items-center justify-center mb-5">
              <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none">
                <path d="M8 12 L20 24 L32 12" stroke="#A55230" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <rect x="8" y="10" width="24" height="18" rx="2" stroke="#A55230" stroke-width="2" fill="none"/>
                <path d="M8 10 L20 23 L32 10" stroke="#A55230" stroke-width="1.5" fill="none" stroke-linecap="round"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl text-contrast mb-3">Handwritten Letter</h3>
            <p class="font-body text-contrast-muted leading-relaxed text-sm">Inspiration behind the piece, creative thoughts, personal reflections, and current life updates from the studio.</p>
          </div>

          <!-- Card 3 — Surprise Gift -->
          <div class="paper-card p-8 hover-lift">
            <div class="w-16 h-16 rounded-full bg-olive-green/20 flex items-center justify-center mb-5">
              <svg class="w-8 h-8" viewBox="0 0 40 40" fill="none">
                <path d="M20 8 C20 8 10 15 10 24 C10 29 14 33 20 33" stroke="#8A8454" stroke-width="2" fill="none" stroke-linecap="round"/>
                <circle cx="17" cy="22" r="2" fill="#8A8454"/>
                <circle cx="23" cy="24" r="1.5" fill="#8A8454"/>
              </svg>
            </div>
            <h3 class="font-display text-2xl text-contrast mb-3">Surprise Gift</h3>
            <p class="font-body text-contrast-muted leading-relaxed text-sm">Every month includes an extra surprise such as a sticker set, bookmark, colouring sheet, mini activity, or build-your-own creative insert.</p>
          </div>

        </div>
      </div>
    </section>
    <section id="archive" class="py-24 px-6 relative overflow-hidden" style="background: linear-gradient(160deg, #D4BB9D 0%, #E7C7AF 56%, #D45C74 100%);">
      <!-- Blob decorations -->
      <div class="absolute top-0 right-0 w-80 h-80 blob-coral rounded-full blur-[100px] animate-blob"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 blob-cinnamon rounded-full blur-[80px] animate-blob float-delay-3"></div>
      <!-- Decorative bg -->
      <div class="absolute top-0 right-0 text-[200px] text-dusty-pink/5 font-display leading-none select-none pointer-events-none">❀</div>

      <div class="max-w-5xl mx-auto">
        <div class="flex items-center gap-4 mb-4">
          <span class="section-label">Club Archive</span>
          <span class="flex-1 h-[2px] bg-coral-pink/30 rounded"></span>
          <span class="font-heading text-xs text-text-muted">Past Print Drops</span>
        </div>

        <h2 class="font-display text-5xl text-text-dark mb-14 mt-4">
          The Collection
        </h2>

        <div class="grid md:grid-cols-3 gap-8">

          <!-- Archive item 1 — MATCHA 2 -->
          <div class="group">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden relative mb-4 hover-lift shadow-lg shadow-dusty-pink/10 border-2 border-coral-pink/20 paper-tilt paper-peel">
              <img
                src="/media/prints/MATCHA 2.png"
                alt="Matcha & Mornings — May 2025 print"
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <!-- Sold out stamp -->
              <div class="absolute top-3 right-3 stamp text-[9px] font-bold text-text-muted bg-white/80">SOLD OUT</div>
              <!-- Washi tape corner -->
              <div class="absolute top-0 left-0 w-16 h-5"
                style="background:repeating-linear-gradient(45deg,rgba(138,132,84,0.6),rgba(138,132,84,0.6) 3px,rgba(231,199,175,0.32) 3px,rgba(231,199,175,0.32) 6px);transform:rotate(-8deg);margin-top:6px;margin-left:6px;"></div>
            </div>
            <h4 class="font-display text-xl text-text-dark">Matcha & Mornings</h4>
            <p class="font-body text-xs text-text-muted mt-1">Warm pastry still life · Coffee cup study · Strawberry stickers</p>
          </div>

          <!-- Archive item 2 — Tulip Selfie → Sunday Reset -->
          <div class="group">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden relative mb-4 hover-lift shadow-lg shadow-coral-pink/10 border-2 border-coral-pink/20">
              <img
                src="/media/prints/tulip selfie.png"
                alt="Sunday Reset — April 2025 print"
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <!-- Sold out stamp -->
              <div class="absolute top-3 right-3 stamp text-[9px] font-bold text-text-muted bg-white/80">SOLD OUT</div>
              <!-- Washi tape corner -->
              <div class="absolute top-0 left-0 w-16 h-5"
                style="background:repeating-linear-gradient(45deg,rgba(212,92,116,0.5),rgba(212,92,116,0.5) 3px,rgba(231,199,175,0.30) 3px,rgba(231,199,175,0.30) 6px);transform:rotate(-8deg);margin-top:6px;margin-left:6px;"></div>
            </div>
            <h4 class="font-display text-xl text-text-dark">Sunday Reset</h4>
            <p class="font-body text-xs text-text-muted mt-1">Soft mornings · Tulip study · Self-care stickers</p>
          </div>

          <!-- Archive item 3 — First Bloom → Toast -->
          <div class="group">
            <div class="aspect-[3/4] rounded-2xl overflow-hidden relative mb-4 hover-lift shadow-lg shadow-burnt-cinnamon/10 border-2 border-burnt-cinnamon/20">
              <img
                src="/media/prints/toastt.png"
                alt="First Bloom — March 2025 print"
                class="w-full h-full object-cover"
                loading="lazy"
              />
              <!-- Sold out stamp -->
              <div class="absolute top-3 right-3 stamp text-[9px] font-bold text-text-muted bg-white/80">SOLD OUT</div>
              <!-- Washi tape corner -->
              <div class="absolute top-0 left-0 w-16 h-5"
                style="background:repeating-linear-gradient(45deg,rgba(222,123,91,0.58),rgba(222,123,91,0.58) 3px,rgba(231,199,175,0.28) 3px,rgba(231,199,175,0.28) 6px);transform:rotate(-8deg);margin-top:6px;margin-left:6px;"></div>
            </div>
            <h4 class="font-display text-xl text-text-dark">First Bloom</h4>
            <p class="font-body text-xs text-text-muted mt-1">Wildflower collage · Pressed flower card · Leaf stickers</p>
          </div>

        </div>

        <div class="text-center mt-10">
          <p class="font-marykate italic text-text-muted text-lg">More issues added every month — join to collect them all.</p>
        </div>
      </div>
    </section>
    <section class="py-24 px-6 relative overflow-hidden" style="background: linear-gradient(160deg, #D4BB9D 0%, #E7C7AF 100%);">

      <!-- Background decorations -->
      <div class="absolute top-0 right-0 w-80 h-80 blob-olive rounded-full blur-[100px] animate-blob"></div>
      <div class="absolute bottom-0 left-0 w-64 h-64 blob-peach rounded-full blur-[80px] animate-blob float-delay-2"></div>

      <div class="max-w-5xl mx-auto relative z-10">

        <!-- Section header -->
        <div class="text-center mb-16">
          <span class="section-label block mb-3">Behind the Studio</span>
          <h2 class="font-display text-5xl text-contrast mb-3">
            Hi, I'm <span class="text-dusty-pink">Tylah</span>
          </h2>
          <p class="font-marykate italic text-contrast-muted text-lg md:text-xl">
            Artist, printmaker, and obsessive flower sketcher — making each issue from my studio with messy hands and a whole lot of care.
          </p>
        </div>

        <!-- ── EDITORIAL COLLAGE LAYOUT ── -->

        <!-- Row 1: Main portrait + text side-by-side -->
        <div class="grid md:grid-cols-2 gap-8 mb-8 items-center">

          <!-- Portrait / Studio image -->
          <div class="relative">
            <div class="aspect-[4/5] rounded-3xl overflow-hidden shadow-xl shadow-dusty-pink/10 border-2 border-coral-pink/20 paper-tilt paper-peel">
              <img
                src="/media/photos/about me.png"
                alt="Tylah's studio workspace with watercolors and flowers"
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <!-- Washi tape decoration -->
            <div class="absolute -top-3 -left-3 w-24 h-6 rounded-sm"
              style="background:repeating-linear-gradient(45deg,rgba(212,92,116,0.6),rgba(212,92,116,0.6) 3px,rgba(231,199,175,0.30) 3px,rgba(231,199,175,0.30) 6px);transform:rotate(-8deg);box-shadow:2px 2px 8px rgba(74,67,54,0.12);">
            </div>
            <!-- Floating sticker -->
            <div class="absolute -bottom-4 -right-4 bg-warm-cream/90 border border-coral-pink/30 rounded-2xl px-3 py-2 shadow-lg">
              <p class="font-retro italic text-xs text-contrast-muted">My happy place ✿</p>
            </div>
          </div>

          <!-- Introduction text -->
          <div>
            <h3 class="font-display text-3xl text-contrast mb-4">The Story Behind<br/><span class="text-dusty-pink">Oopsie Daisy</span></h3>
            <p class="font-body text-contrast-muted leading-relaxed mb-4">
